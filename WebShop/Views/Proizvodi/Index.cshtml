@model IEnumerable<WebShop.Models.Proizvod>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Katalog";
    string? uloga = Context.Session.GetString("KorisnikUloga");
}

<style>
    .page-header { margin-bottom: 2rem; }
    .page-header h1 { font-size: 1.9rem; font-weight: 800; letter-spacing: -0.5px; color: #0f172a; margin: 0; }
    .page-header p  { color: #64748b; font-size: 0.9rem; margin: 0.25rem 0 0; }

    .filter-bar {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
    }

    .product-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: box-shadow 0.2s, transform 0.2s;
    }
    .product-card:hover {
        box-shadow: 0 16px 36px rgba(0,0,0,0.08);
        transform: translateY(-4px);
    }
    .product-img-wrap {
        background: #f8fafc;
        height: 220px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .product-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }
    .product-card:hover .product-img-wrap img { transform: scale(1.04); }

    .product-body { padding: 1.25rem; display: flex; flex-direction: column; flex: 1; }

    .cat-badge {
        display: inline-block;
        background: #eff6ff;
        color: #3b82f6;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        margin-bottom: 0.6rem;
    }

    .product-name { font-size: 0.97rem; font-weight: 700; color: #0f172a; margin-bottom: 0.4rem; line-height: 1.3; }
    .product-desc { font-size: 0.83rem; color: #64748b; line-height: 1.5; flex: 1; margin-bottom: 0.75rem; }
    .product-price { font-size: 1.4rem; font-weight: 800; color: #0f172a; }

    .btn-add { border-radius: 10px; font-weight: 600; font-size: 0.88rem; padding: 0.5rem; }
    .btn-wish { border-radius: 10px; font-weight: 500; font-size: 0.83rem; padding: 0.45rem; }
    .btn-admin { border-radius: 10px; font-size: 0.83rem; padding: 0.4rem 0.75rem; }

    .out-of-stock-badge {
        background: #fef2f2;
        color: #ef4444;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.72rem;
        font-weight: 700;
    }
</style>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <h1>TechGear Katalog</h1>
        <p>Vrhunski hardver i dodaci po ekskluzivnim cijenama.</p>
    </div>
    @if (uloga == "Admin")
    {
        <a asp-action="Create" class="btn btn-success rounded-3 px-4 py-2 fw-bold shadow-sm">+ Dodaj artikl</a>
    }
</div>

<div class="filter-bar">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-semibold text-secondary mb-1">Pretraži po nazivu</label>
            <input type="text" name="searchString" value="@ViewData["TrenutnaPretraga"]"
                   class="form-control rounded-3" placeholder="Npr. Monitor, Tipkovnica..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold text-secondary mb-1">Kategorija</label>
            <select name="kategorija" class="form-select rounded-3">
                <option value="">Sve kategorije</option>
                @if (ViewBag.SveKategorije != null)
                {
                    foreach (var kat in ViewBag.SveKategorije)
                    {
                        <option value="@kat" selected="@(kat == (string?)ViewData["TrenutnaKategorija"])">@kat</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold text-secondary mb-1">Sortiraj po cijeni</label>
            <select name="sortOrder" class="form-select rounded-3">
                <option value="">Zadano (A–Z)</option>
                <option value="cijena_asc"  selected="@((string?)ViewData["TrenutnoSortiranje"] == "cijena_asc")">Najjeftinije prvo</option>
                <option value="cijena_desc" selected="@((string?)ViewData["TrenutnoSortiranje"] == "cijena_desc")">Najskuplje prvo</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-3 w-100 fw-semibold">Primijeni</button>
            @if (!string.IsNullOrEmpty((string?)ViewData["TrenutnaPretraga"]) ||
                 !string.IsNullOrEmpty((string?)ViewData["TrenutnaKategorija"]) ||
                 !string.IsNullOrEmpty((string?)ViewData["TrenutnoSortiranje"]))
            {
                <a asp-action="Index" class="btn btn-outline-secondary rounded-3" title="Poništi filtere">✕</a>
            }
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="fs-1 mb-3 text-muted">🔍</div>
        <h5 class="fw-bold text-dark">Nema rezultata</h5>
        <p class="text-muted small">Pokušajte s drugačijim filterima.</p>
        <a asp-action="Index" class="btn btn-outline-primary rounded-3 px-4">Prikaži sve</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="product-card shadow-sm">
                    <a asp-action="Details" asp-route-id="@item.ProizvodID">
                        <div class="product-img-wrap">
                            @if (!string.IsNullOrEmpty(item.SlikaUrl))
                            {
                                <img src="@item.SlikaUrl" alt="@item.Naziv">
                            }
                            else
                            {
                                <img src="https://placehold.co/400x220/f1f5f9/94a3b8?text=TechGear" alt="Nema slike">
                            }
                        </div>
                    </a>

                    <div class="product-body">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span class="cat-badge">@item.Kategorija</span>
                            @if (item.Lager == 0)
                            {
                                <span class="out-of-stock-badge">Rasprodano</span>
                            }
                        </div>

                        <a asp-action="Details" asp-route-id="@item.ProizvodID" class="text-decoration-none">
                            <div class="product-name">@item.Naziv</div>
                        </a>

                        <p class="product-desc">
                            @(item.Opis?.Length > 90 ? item.Opis.Substring(0, 85) + "…" : item.Opis)
                        </p>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="product-price">@item.Cijena.ToString("F2") €</span>
                            <a asp-action="Details" asp-route-id="@item.ProizvodID"
                               class="text-decoration-none text-primary small fw-semibold">Detalji →</a>
                        </div>

                        @if (uloga == "Admin")
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.ProizvodID"
                                   class="btn btn-outline-secondary btn-admin w-50">Uredi</a>
                                <form asp-action="Delete" asp-route-id="@item.ProizvodID" method="post"
                                      onsubmit="return confirm('Sigurno želiš ukloniti ovaj proizvod?');" class="m-0 w-50">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-admin w-100">Ukloni</button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2">
                                <form asp-controller="Kosarica" asp-action="Dodaj" asp-route-id="@item.ProizvodID"
                                      method="post" class="m-0 kosarica-form" data-product-id="@item.ProizvodID">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary btn-add w-100" @(item.Lager == 0 ? "disabled" : "")>
                                        🛒 Dodaj u košaricu
                                    </button>
                                </form>
                                <form asp-controller="Wishlist" asp-action="DodajUlistu" asp-route-id="@item.ProizvodID" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-wish w-100">
                                        ♡ Lista želja
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
