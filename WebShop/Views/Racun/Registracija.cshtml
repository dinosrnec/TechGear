@model WebShop.Models.Korisnik

@{
    ViewData["Title"] = "Registracija";
}

<style>
    .auth-wrap {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .auth-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 2.75rem 2.5rem;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.06);
    }
    .auth-logo  { font-size: 1.3rem; font-weight: 800; color: #0f172a; margin-bottom: 0.25rem; }
    .auth-logo span { color: #3b82f6; }
    .auth-title { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 0.25rem; letter-spacing: -0.3px; }
    .auth-sub   { font-size: 0.88rem; color: #64748b; margin-bottom: 2rem; }
    .form-label { font-size: 0.82rem; font-weight: 600; color: #475569; margin-bottom: 0.35rem; }
    .form-control { border-color: #e2e8f0; border-radius: 10px; padding: 0.6rem 0.9rem; font-size: 0.92rem; }
    .form-control:focus  { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.12); }
    .form-control.is-invalid { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.12) !important; }
    .field-error { font-size: 0.78rem; color: #ef4444; margin-top: 4px; display: none; }
    .btn-submit { border-radius: 10px; padding: 0.65rem; font-weight: 700; font-size: 0.95rem; }
    .auth-footer { font-size: 0.85rem; color: #64748b; margin-top: 1.5rem; text-align: center; }
    .auth-footer a { color: #3b82f6; font-weight: 600; text-decoration: none; }
    .auth-footer a:hover { text-decoration: underline; }

    /* Validation popup */
    #val-popup {
        position: fixed;
        top: 1.5rem;
        left: 50%;
        transform: translateX(-50%);
        background: #fff;
        border: 1px solid #fecaca;
        border-left: 4px solid #ef4444;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        z-index: 9999;
        min-width: 300px;
        max-width: 420px;
        display: none;
        animation: slideDown 0.2s ease;
    }
    @@keyframes slideDown {
        from { opacity: 0; transform: translateX(-50%) translateY(-12px); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
    #val-popup .popup-title { font-weight: 700; color: #b91c1c; font-size: 0.92rem; margin-bottom: 0.35rem; }
    #val-popup ul { margin: 0; padding-left: 1.1rem; color: #374151; font-size: 0.86rem; line-height: 1.7; }

    /* Password strength bar */
    .strength-bar-wrap { height: 4px; background: #f1f5f9; border-radius: 4px; margin-top: 6px; overflow: hidden; }
    .strength-bar      { height: 100%; border-radius: 4px; transition: width 0.3s, background 0.3s; width: 0; }
    .strength-label    { font-size: 0.75rem; margin-top: 3px; font-weight: 600; }
</style>

<!-- Validation popup -->
<div id="val-popup">
    <div class="popup-title">⚠️ Ispravite sljedeće:</div>
    <ul id="val-list"></ul>
</div>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">⚡ <span>Tech</span>Gear</div>
        <h2 class="auth-title">Kreirajte račun</h2>
        <p class="auth-sub">Pridružite se TechGear zajednici</p>

        <form asp-action="Registracija" method="post" id="regForm" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 py-2 small mb-3 text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email adresa</label>
                <input asp-for="Email" id="fEmail" class="form-control" placeholder="ime@primjer.com" autocomplete="email" />
                <div class="field-error" id="err-email">Unesite ispravnu email adresu (npr. ime&#64;gmail.com)</div>
            </div>

            <div class="mb-3">
                <label asp-for="Lozinka" class="form-label">Lozinka</label>
                <div class="input-group">
                    <input asp-for="Lozinka" type="password" id="fLozinka" class="form-control"
                           placeholder="Min. 8 znakova" autocomplete="new-password" />
                    <button type="button" class="btn btn-outline-secondary px-3" id="toggleLoz"
                            style="border-color:#e2e8f0; border-radius:0 10px 10px 0;" title="Prikaži lozinku">
                        <span id="eyeLoz">👁</span>
                    </button>
                </div>
                <div class="strength-bar-wrap mt-1">
                    <div class="strength-bar" id="strengthBar"></div>
                </div>
                <div class="strength-label" id="strengthLabel" style="color:#94a3b8;"></div>
                <div class="field-error" id="err-lozinka">Lozinka mora imati najmanje 8 znakova</div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="Ime" class="form-label">Ime <span style="color:#ef4444;">*</span></label>
                    <input asp-for="Ime" id="fIme" class="form-control" placeholder="Ana" />
                    <div class="field-error" id="err-ime">Ime je obavezno</div>
                </div>
                <div class="col-6">
                    <label asp-for="Prezime" class="form-label">Prezime <span style="color:#ef4444;">*</span></label>
                    <input asp-for="Prezime" id="fPrezime" class="form-control" placeholder="Horvat" />
                    <div class="field-error" id="err-prezime">Prezime je obavezno</div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-submit w-100">Stvori račun</button>
        </form>

        <div class="auth-footer">
            Već imate račun? <a asp-action="Login">Prijavite se</a>
        </div>
    </div>
</div>

<script>
(function () {
    // ── Password show/hide ──
    const toggleLoz = document.getElementById('toggleLoz');
    const fLozinka  = document.getElementById('fLozinka');
    const eyeLoz    = document.getElementById('eyeLoz');
    toggleLoz.addEventListener('click', function () {
        const vis = fLozinka.type === 'text';
        fLozinka.type = vis ? 'password' : 'text';
        eyeLoz.textContent = vis ? '👁' : '🙈';
    });

    // ── Password strength ──
    const strengthBar   = document.getElementById('strengthBar');
    const strengthLabel = document.getElementById('strengthLabel');
    fLozinka.addEventListener('input', function () {
        const v = fLozinka.value;
        let score = 0;
        if (v.length >= 8)  score++;
        if (v.length >= 12) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;
        const levels = [
            { w: '20%', bg: '#ef4444', lbl: 'Vrlo slaba',  col: '#ef4444' },
            { w: '40%', bg: '#f97316', lbl: 'Slaba',       col: '#f97316' },
            { w: '60%', bg: '#eab308', lbl: 'Srednja',     col: '#eab308' },
            { w: '80%', bg: '#22c55e', lbl: 'Jaka',        col: '#22c55e' },
            { w: '100%',bg: '#16a34a', lbl: 'Vrlo jaka',   col: '#16a34a' },
        ];
        const lvl = v.length === 0 ? null : levels[Math.min(score, 4)];
        if (lvl) {
            strengthBar.style.width      = lvl.w;
            strengthBar.style.background = lvl.bg;
            strengthLabel.textContent    = lvl.lbl;
            strengthLabel.style.color    = lvl.col;
        } else {
            strengthBar.style.width = '0';
            strengthLabel.textContent = '';
        }
    });

    // ── Validation helpers ──
    function showError(inputId, errId, show) {
        const input = document.getElementById(inputId);
        const err   = document.getElementById(errId);
        if (show) {
            input.classList.add('is-invalid');
            err.style.display = 'block';
        } else {
            input.classList.remove('is-invalid');
            err.style.display = 'none';
        }
    }

    function isValidEmail(email) {
        return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]{2,}$/.test(email);
    }

    // Clear errors on input
    document.getElementById('fEmail').addEventListener('input',   function () { showError('fEmail',   'err-email',   false); });
    document.getElementById('fLozinka').addEventListener('input', function () { showError('fLozinka', 'err-lozinka', false); });
    document.getElementById('fIme').addEventListener('input',     function () { showError('fIme',     'err-ime',     false); });
    document.getElementById('fPrezime').addEventListener('input', function () { showError('fPrezime', 'err-prezime', false); });

    // ── Form submit ──
    document.getElementById('regForm').addEventListener('submit', function (e) {
        const email   = document.getElementById('fEmail').value.trim();
        const lozinka = document.getElementById('fLozinka').value;
        const ime     = document.getElementById('fIme').value.trim();
        const prezime = document.getElementById('fPrezime').value.trim();

        const errors = [];
        let first = null;

        if (!isValidEmail(email)) {
            showError('fEmail', 'err-email', true);
            errors.push('Unesite ispravnu email adresu (npr. ime@gmail.com)');
            if (!first) first = 'fEmail';
        }
        if (lozinka.length < 8) {
            showError('fLozinka', 'err-lozinka', true);
            errors.push('Lozinka mora imati najmanje 8 znakova');
            if (!first) first = 'fLozinka';
        }
        if (!ime) {
            showError('fIme', 'err-ime', true);
            errors.push('Ime je obavezno');
            if (!first) first = 'fIme';
        }
        if (!prezime) {
            showError('fPrezime', 'err-prezime', true);
            errors.push('Prezime je obavezno');
            if (!first) first = 'fPrezime';
        }

        if (errors.length > 0) {
            e.preventDefault();
            // Show popup
            const list = document.getElementById('val-list');
            list.innerHTML = errors.map(err => '<li>' + err + '</li>').join('');
            const popup = document.getElementById('val-popup');
            popup.style.display = 'block';
            // Focus first invalid field
            if (first) document.getElementById(first).focus();
            // Auto-hide after 5s
            clearTimeout(popup._timer);
            popup._timer = setTimeout(() => { popup.style.display = 'none'; }, 5000);
        }
    });
})();
</script>
